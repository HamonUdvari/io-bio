---
import type { ImageMetadata } from "astro";
import { Image as AstroImage } from "astro:assets";

interface Props {
  imagePath: string;
  alt: string;
  class?: string;
}

const { imagePath: inputImagePath, alt = "Image alt", ...props } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/bios/**/*.{svg,jpeg,jpg,png,gif}",
);

// Look up by NFC-normalised basename so Unicode characters (è, ö) match
// regardless of whether Vite serves keys in NFC or NFD.
const wantedBase = (inputImagePath ?? "").split("/").pop()?.normalize("NFC");
const loader = wantedBase
  ? Object.entries(images).find(
      ([k]) => k.split("/").pop()?.normalize("NFC") === wantedBase,
    )?.[1]
  : undefined;

if (!loader && wantedBase) {
  console.error(
    `Image "${wantedBase}" not found in glob "/src/assets/bios/**/*.{svg,jpeg,jpg,png,gif}"`,
  );
}

// Serve a downsized webp instead of the full-resolution scan. The portrait
// displays at ~320px, so capping at ~1200px (≈3.5×) stays crisp on screen and
// in the generated entry PDF (which embeds whatever the page renders). Capped
// at the source's intrinsic width, so small crops are never upscaled. Without
// this a 4296px source shipped a ~2.7MB image and produced ~28MB PDFs.
const MAX_WIDTH = 1200;
const meta = loader ? (await loader()).default : undefined;
const renderWidth = meta ? Math.min(MAX_WIDTH, meta.width) : undefined;
---

{meta && (
  <AstroImage src={meta} alt={alt} quality={92} width={renderWidth} {...props} />
)}
