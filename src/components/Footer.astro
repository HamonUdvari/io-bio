---
import Nav from "@components/Nav.astro";
import { frontmatter } from "@content/globals/footer.md";
import { marked } from "marked";
// `breaks: true` turns each newline into a <br> so the footer keeps its
// three-line layout without relying on trailing-space hard breaks.
const html = marked(frontmatter.text ?? "", { breaks: true });
---

<footer class="footer flex flex-col">
  <div class="footer__text" set:html={html} />
  <Nav />
</footer>
