---
import { getCollection } from "astro:content";
import ListView from "@components/ListView";
import { getImage } from "astro:assets";

const bios = await getCollection("bios");
const biosData = bios.map((bio) => ({ slug: bio.id, ...bio.data }));

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/bios/**/*.{svg,jpeg,jpg,png,gif}",
);

// Build a lookup keyed on the basename in NFC normalization. Vite's glob keys
// can arrive in NFD on macOS while the docxLoader emits NFC filenames; this
// makes the lookup tolerant of both.
const imagesByBasename = new Map<
  string,
  () => Promise<{ default: ImageMetadata }>
>();
for (const [k, loader] of Object.entries(images)) {
  const base = k.split("/").pop()!.normalize("NFC");
  imagesByBasename.set(base, loader);
}

for (let bioData of biosData) {
  // Prefer the face-cropped portrait for the listing/grid view; fall back to
  // the original if no portrait was generated.
  const imageFn = bioData.imagePortraitFn || bioData.imageFn;
  if (!imageFn) continue;

  const loader = imagesByBasename.get(imageFn.normalize("NFC"));
  if (!loader) continue;

  const importedImg = await loader();
  if (!importedImg) continue;

  const webImage = await getImage({ src: importedImg.default, quality: 92 });
  bioData.webImage = webImage;
}
  
---

<ListView data={biosData} client:load />
