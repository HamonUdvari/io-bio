---
import Layout from "@layouts/Layout.astro";
import Image from "@components/Image.astro";
import { render } from "astro:content";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const bios = await getCollection("bios");

  return bios.map((page) => {
    const { id } = page;

    return {
      params: { slug: id },
      props: { ...page },
    };
  });
}

const { data } = Astro.props;
const {
  image,
  lastName,
  firstName,
  archives,
  publications,
  literature,
  roles = [],
  imageSource,
  summary,
  authors,
  version,
  imageFn,
  life,
} = data;

if (!image) {
  throw new Error("Image was missing");
}

const title = `${lastName.toUpperCase()}, ${firstName}`;
const description = summary;
const { Content } = await render(Astro.props);

// --- How to cite ----------------------------------------------------------
// IO BIO uses Zenodo for DOIs (Option 3a hybrid): a whole-dictionary concept
// DOI plus an entry-level citation string carrying author/title/version/slug.
// TODO: replace with the real IO BIO Zenodo concept DOI once minted.
const IOBIO_CONCEPT_DOI = "10.5281/zenodo.0000000";

const slug = Astro.params.slug ?? Astro.props.id;

// "Version 4 November 2019" → "4 November 2019"
const versionLabel = (version ?? "").replace(/^Version\s+/i, "").trim();

// Citation year: explicit frontmatter, else the trailing 4-digit year parsed
// from the version date, the title, or the slug.
const parsedYear =
  Number(
    (versionLabel.match(/\b(\d{4})\b\s*$/) ??
      title.match(/\b(\d{4})\b/) ??
      slug.match(/\b(\d{4})\b/) ??
      [])[1],
  ) || undefined;
const year = data.publishedYear ?? parsedYear;

// Base-aware canonical URL, e.g. https://…/io-bio/entries/<slug>
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const SITE = import.meta.env.SITE;
const entryUrl = new URL(`${base}entries/${slug}`, SITE).href;

const citationDoi = data.versionDoi ?? data.conceptDoi ?? IOBIO_CONCEPT_DOI;
const conceptDoi = data.conceptDoi;
const doiIsExample = !(data.versionDoi || data.conceptDoi);

const fallbackDate = versionLabel || "[date]";

// Image credit: if the source contains a URL, show just the host (a short,
// clickable label) with the full URL on click — long source URLs otherwise
// overflow the rotated caption. Non-URL sources render verbatim.
function parseImageSource(src) {
  if (!src) return { text: "", href: null, label: null };
  const m = src.match(/(https?:\/\/[^\s]+|www\.[^\s]+)/i);
  if (!m) return { text: src, href: null, label: null };
  const raw = m[0].replace(/[).,;]+$/, "");
  const href = raw.startsWith("http") ? raw : `https://${raw}`;
  let label = raw;
  try {
    label = new URL(href).hostname.replace(/^www\./, "");
  } catch {}
  const text = src.slice(0, m.index).replace(/[\s/–—-]+$/, "").trim();
  return { text, href, label };
}
const source = parseImageSource(imageSource);
---

<Layout title={title} description={description}>
  <section
    class="border-t-0 bg-io-gray-600 pt-[5rem] pb-[7.5rem] text-center gap-y-[30px]"
  >
    <figure class="relative max-w-[345px] _max-h-[414px]">
      <picture>
        <Image class="w-full" imagePath={imageFn} alt={title} />
      </picture>
      <figcaption
        class="text-credit absolute left-full bottom-0 ml-4 origin-bottom-left -rotate-90 whitespace-nowrap"
      >
        Source:{" "}
        {!source.href && imageSource}
        {source.href && (
          <>
            {source.text && <>{source.text} </>}
            <a href={source.href} target="_blank" rel="noopener noreferrer">
              {source.label}
            </a>
          </>
        )}
      </figcaption>
    </figure>
    <div class="flex flex-col items-center gap-y-5 leading-none">
      <h1 class="text-h2 leading-none">{title}</h1>
      <h2 class="text-h2 max-w-[45ch] leading-none">{summary}</h2>
    </div>
    <div class="flex flex-row mx-auto items-center justify-center">
      <span>By {authors}</span>
      <span>{version}</span>
    </div>
    <span class="mt-[30px] text-balance">{life}</span>
    <button
      class="button button--primary button--download w-fit print:hidden"
      onclick="window.print()">Download Entry PDF</button
    >
  </section>
  <section id="biography">
    <h2 class="section__title">Biography</h2>
    <Content />
  </section>
  {
    archives?.items?.length > 0 && (
      <section id="archives">
        <h2 class="section__title">Archives</h2>
        {archives.items.length === 1 ? (
          <p>{archives.items[0].raw}</p>
        ) : (
          <ul>
            {archives.items.map((c) => (
              <li>{c.raw}</li>
            ))}
          </ul>
        )}
        {archives.websitesAccessedOn && (
          <p class="text-sm opacity-70">
            (all websites accessed {archives.websitesAccessedOn})
          </p>
        )}
      </section>
    )
  }
  {
    publications?.items?.length > 0 && (
      <section id="publications">
        <h2 class="section__title">Publications</h2>
        {publications.items.length === 1 ? (
          <p>{publications.items[0].raw}</p>
        ) : (
          <ul>
            {publications.items.map((c) => (
              <li>{c.raw}</li>
            ))}
          </ul>
        )}
        {publications.websitesAccessedOn && (
          <p class="text-sm opacity-70">
            (all websites accessed {publications.websitesAccessedOn})
          </p>
        )}
      </section>
    )
  }
  {
    literature?.items?.length > 0 && (
      <section id="literature">
        <h2 class="section__title">Literature</h2>
        {literature.items.length === 1 ? (
          <p>{literature.items[0].raw}</p>
        ) : (
          <ul>
            {literature.items.map((c) => (
              <li>{c.raw}</li>
            ))}
          </ul>
        )}
        {literature.websitesAccessedOn && (
          <p class="text-sm opacity-70">
            (all websites accessed {literature.websitesAccessedOn})
          </p>
        )}
      </section>
    )
  }
  <section id="cite">
    <h2 class="section__title">How to cite</h2>

    <div class="cite__block">
      <h3 class="cite__label">Cite this entry — DOI</h3>
      <p class="cite__text" id="cite-doi">
        {authors} ({year}). {lastName}, {firstName} (Version {versionLabel})
        [Biographical entry]. <cite>IO BIO — Biographical Dictionary of
        Secretaries-General of International Organizations</cite>. Zenodo.
        https://doi.org/{citationDoi}
      </p>
      {
        doiIsExample && (
          <p class="cite__note">(example DOI — pending Zenodo deposit)</p>
        )
      }
      <div class="button-group">
        <button class="button button--secondary" data-copy-target="cite-doi"
          >Copy citation</button
        >
        {
          conceptDoi && (
            <a
              class="button button--secondary"
              href={`https://doi.org/${conceptDoi}`}
            >
              Always-latest DOI
            </a>
          )
        }
      </div>
    </div>

    <div class="cite__block">
      <h3 class="cite__label">Cite this entry — web</h3>
      <p class="cite__text" id="cite-web">
        {authors}, '{lastName}, {firstName}' in <cite>IO BIO, Biographical
        Dictionary of Secretaries-General of International Organizations</cite>,
        edited by Bob Reinalda, Kent J. Kille and Jaci L. Eisenberg, {entryUrl},
        accessed <span data-accessed>{fallbackDate}</span>.
      </p>
      <div class="button-group">
        <button class="button button--secondary" data-copy-target="cite-web"
          >Copy citation</button
        >
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const monthNames = [
        "January", "February", "March", "April", "May", "June",
        "July", "August", "September", "October", "November", "December",
      ];
      function todayLabel() {
        const d = new Date();
        return `${d.getDate()} ${monthNames[d.getMonth()]} ${d.getFullYear()}`;
      }

      function stampAccessed(root) {
        (root || document)
          .querySelectorAll("[data-accessed]")
          .forEach((el) => {
            el.textContent = todayLabel();
          });
      }

      // On load: replace the pre-JS fallback date with today's real date.
      stampAccessed(document);

      document.querySelectorAll("[data-copy-target]").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const target = document.getElementById(
            btn.getAttribute("data-copy-target"),
          );
          if (!target) return;
          // Re-stamp so a copied citation always carries the true access date.
          stampAccessed(target);
          const text = target.textContent.replace(/\s+/g, " ").trim();
          try {
            await navigator.clipboard.writeText(text);
          } catch (e) {
            return;
          }
          const original = btn.textContent;
          btn.textContent = "Copied";
          setTimeout(() => {
            btn.textContent = original;
          }, 1500);
        });
      });
    })();
  </script>
</Layout>
