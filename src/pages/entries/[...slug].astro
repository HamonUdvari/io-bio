---
import Layout from "@layouts/Layout.astro";
import EntryArticle from "@components/EntryArticle.astro";
import { render } from "astro:content";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const bios = await getCollection("bios");

  return bios.map((page) => {
    const { id } = page;

    return {
      params: { slug: id },
      props: { ...page },
    };
  });
}

const { data } = Astro.props;
const { lastName, firstName, summary } = data;

const title = `${lastName.toUpperCase()}, ${firstName}`;
const description = summary;
const { Content } = await render(Astro.props);

const slug = Astro.params.slug ?? Astro.props.id;

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
// Pre-rendered entry PDF (generated by scripts/zenodo-render-pdfs.ts) served as
// a static asset alongside the entry; the Download button links here.
const pdfHref = `${base}entries/${slug}.pdf`;
// Live Paged.js print preview (the design surface; also what the PDF is rendered
// from) — the debug link opens it.
const printHref = `${base}print/${slug}`;

// Per-entry Zenodo SANDBOX record link — a build-time debug aid (next to the
// print-preview debug control) to eyeball the sandbox deposit. Points at the
// CONCEPT record (conceptRecId, always-latest), matching the "How to cite"
// citation built in docxLoader, so both Zenodo surfaces on the page resolve to
// the same deposit. Read the sandbox DOI map via glob so the build won't fail
// when it's absent; independent of ZENODO_ENV.
const sandboxDoiMap = (Object.values(
  import.meta.glob("/src/data/zenodo-dois.sandbox.json", {
    eager: true,
    import: "default",
  }),
)[0] ?? {}) as Record<
  string,
  { recordId?: number | string; conceptRecId?: number | string }
>;
const sandboxRec = sandboxDoiMap[slug ?? ""];
const sandboxRecordId = sandboxRec?.conceptRecId ?? sandboxRec?.recordId;
const sandboxUrl = sandboxRecordId
  ? `https://sandbox.zenodo.org/records/${sandboxRecordId}`
  : null;
---

<Layout title={title} description={description}>
  <EntryArticle data={data} Content={Content}>
    <div slot="controls" class="flex flex-col items-center gap-y-3 print:hidden">
      <a
        class="button button--primary button--download"
        href={pdfHref}
        download={`${slug}-iobio.pdf`}
        >Download (PDF)</a
      >
      {/* Debug links (screen only): the live browser-print view for iterating
          on print styles, and the per-entry Zenodo sandbox deposit if minted. */}
      <div class="flex flex-row gap-x-4 text-small">
        <!-- <a -->
        <!--   class="cursor-pointer underline opacity-70 hover:opacity-100" -->
        <!--   href={printHref}>Print preview</a -->
        <!-- > -->
        {sandboxUrl && (
          <a
            class="underline opacity-70 hover:opacity-100"
            href={sandboxUrl}
            target="_blank"
            rel="noopener noreferrer">Zenodo</a
          >
        )}
      </div>
    </div>
  </EntryArticle>
</Layout>
