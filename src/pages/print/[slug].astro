---
// Paged.js print-preview route — the design surface for the entry PDF and the
// source the headless-Chrome render prints. It renders ONLY the printable
// <EntryArticle> (no Layout/nav/footer/screen controls) and runs Paged.js in
// the browser, so the paginated A4 layout + @page footer are visible and
// inspectable live. The deployed PDF (scripts/zenodo-render-pdfs.ts) prints
// THIS route, so the preview is identical to the download.
import "@styles/global.css";
import EntryArticle from "@components/EntryArticle.astro";
import { render, getCollection } from "astro:content";

export async function getStaticPaths() {
  const bios = await getCollection("bios");
  return bios.map((page) => ({
    params: { slug: page.id },
    props: { ...page },
  }));
}

const { data } = Astro.props;
const { lastName, firstName } = data;
const { Content } = await render(Astro.props);

const slug = Astro.params.slug ?? Astro.props.id;
const title = `${lastName.toUpperCase()}, ${firstName}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{`Print · ${title}`}</title>
  </head>
  <body class="pagedjs-print-root">
    <EntryArticle data={data} Content={Content} />

    <script>
      import { Previewer } from "pagedjs";

      async function paginate() {
        // font-display:block → glyphs are invisible until loaded; paginate only
        // after fonts settle so Paged.js measures with final metrics (it lays
        // out once and won't reflow afterwards).
        if (document.fonts?.ready) {
          try {
            await document.fonts.ready;
          } catch {}
        }
        const flow = await new Previewer().preview();

        // Separate each A4 page into a distinct, centred sheet (gap + drop
        // shadow) so the page breaks are clearly visible in the live preview.
        // Injected AFTER preview() because Paged.js's polisher consumes the
        // author stylesheets and drops @media screen blocks (it keeps @media
        // print, which is how the preview mirrors the PDF) — a style added now
        // is left untouched. Wrapped in @media screen so it never reaches the
        // PDF: Page.printToPDF renders in print media, where each .pagedjs_page
        // is already a real page.
        const sep = document.createElement("style");
        sep.textContent = `@media screen {
          .pagedjs_pages { padding-block: 12mm; }
          .pagedjs_page { margin: 0 auto 12mm; }
          .pagedjs_pagebox { box-shadow: 0 0 0 1px rgb(0 0 0 / 0.08), 0 2px 8px rgb(0 0 0 / 0.28); }
        }`;
        document.head.appendChild(sep);

        // Marker the headless-Chrome renderer polls before Page.printToPDF.
        document.documentElement.dataset.pagedjsReady = "true";
        document.documentElement.dataset.pagedjsPages = String(flow?.total ?? "");
      }
      paginate();

      // Dev only: Astro CSS HMR injects styles without a reload, but Paged.js
      // paginates once — so force a full reload on any HMR update to re-run it.
      if (import.meta.hot) {
        import.meta.hot.on("vite:afterUpdate", () => location.reload());
      }
    </script>
  </body>
</html>
