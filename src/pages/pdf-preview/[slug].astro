---
// DEV-ONLY live PDF viewer. Embeds the on-demand-rendered entry PDF
// (/entries/<slug>.pdf, served by the dev-pdf-renderer integration) in an
// iframe and reloads it whenever Vite pushes an HMR update — so you can watch
// the ACTUAL rendered PDF refresh as you edit print CSS, not just the HTML
// /print preview. getStaticPaths returns [] outside dev, so this route emits
// no pages in the production build. Importing global.css wires this shell into
// the CSS module graph, so a global.css save fires vite:afterUpdate here.
import "@styles/global.css";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  if (!import.meta.env.DEV) return [];
  const bios = await getCollection("bios");
  return bios.map((page) => ({ params: { slug: page.id } }));
}

const { slug } = Astro.params;
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const pdfHref = `${base}entries/${slug}.pdf`;
const printHref = `${base}print/${slug}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{`Live PDF · ${slug}`}</title>
    <style>
      html,
      body {
        margin: 0;
        height: 100%;
        background: #525659;
      }
      .bar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 32px;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 0 12px;
        font:
          12px/32px ui-monospace,
          monospace;
        color: #ddd;
        background: #2b2b2b;
        z-index: 1;
      }
      .bar a {
        color: #9cf;
      }
      .bar .live {
        color: #6e6;
      }
      iframe {
        position: fixed;
        inset: 32px 0 0 0;
        width: 100%;
        height: calc(100% - 32px);
        border: 0;
      }
    </style>
  </head>
  <body>
    <div class="bar">
      <span class="live" id="status">● live</span>
      <span>{slug}.pdf — reloads on save</span>
      <a href={printHref}>open /print (HTML)</a>
    </div>
    <iframe id="pdf" title={`${slug} PDF`} src={pdfHref} data-pdf={pdfHref}></iframe>

    <script>
      const iframe = document.getElementById("pdf") as HTMLIFrameElement;
      const status = document.getElementById("status")!;
      const reload = () => {
        // Cache-bust so the iframe re-fetches; the dev middleware re-renders the
        // PDF from the current CSS (Cache-Control: no-store also prevents reuse).
        status.textContent = "● rendering…";
        iframe.src = `${iframe.dataset.pdf}?t=${Date.now()}`;
      };
      iframe.addEventListener("load", () => {
        status.textContent = "● live";
      });
      if (import.meta.hot) {
        import.meta.hot.on("vite:afterUpdate", reload);
      }
    </script>
  </body>
</html>
