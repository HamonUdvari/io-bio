---
import "@styles/global.css";
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";
import { frontmatter as globals } from "@content/globals/global.md";

const SITE = import.meta.env.SITE;
// Normalise BASE_URL to exactly one trailing slash. Astro's BASE_URL mirrors
// the configured `base`, so it may be "/io-bio" (no slash), "/io-bio/", or "/".
// Forcing one trailing slash lets us join `${BASE}path` (path without a leading
// slash) safely in every case.
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const { title: globalTitle, description: globalDescription } = globals;
const {
  title = globalTitle,
  description = globalDescription,
  hideFooter = false,
} = Astro.props;

const image = new URL(`${BASE}og.jpg`, SITE).toString();
const currentUrl = new URL(Astro.url.pathname, SITE).toString();
const locale = Astro.currentLocale;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={currentUrl} />

    <meta property="og:url" content={currentUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <meta property="og:locale" content={locale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <link rel="manifest" href={`${BASE}site.webmanifest`} />

    <link
      rel="icon"
      href={`${BASE}android-chrome-192x192.png`}
      sizes="192x192"
      type="image/png"
    />
    <link
      rel="icon"
      href={`${BASE}android-chrome-512x512.png`}
      sizes="512x512"
      type="image/png"
    />

    <link rel="apple-touch-icon" href={`${BASE}apple-touch-icon.png`} />
    <link rel="icon" href={`${BASE}fav.jpg`} type="image/jpeg" />
    <link
      rel="icon"
      href={`${BASE}favicon-16x16.png`}
      sizes="16x16"
      type="image/png"
    />
    <link
      rel="icon"
      href={`${BASE}favicon-32x32.png`}
      sizes="32x32"
      type="image/png"
    />
    <link rel="shortcut icon" href={`${BASE}favicon.ico`} type="image/x-icon" />
    <script is:inline define:vars={{ base: BASE }}>
      (function () {
        // `base` ends in "/" (e.g. "/io-bio/" or "/"). The homepage is served at
        // exactly `base`, optionally with a trailing slash, so compare both forms.
        var home = base;
        var homeNoSlash = base.length > 1 ? base.replace(/\/$/, "") : base;
        if (location.pathname !== home && location.pathname !== homeNoSlash)
          return;
        var p = new URLSearchParams(location.search);
        if (p.has("q") || p.has("view") || p.has("sort")) {
          document.documentElement.classList.add("entries-restoring");
        }
      })();
    </script>
    <script is:inline>
      // Suppress transitions/animations while the window is actively resizing,
      // so responsive layout shifts (breakpoint changes, fluid widths) don't
      // visibly animate. Adds `.resizing` to <html> during resize and removes
      // it ~150ms after it stops; the matching CSS rule (global.css) zeroes out
      // transitions + animations while the class is present.
      (function () {
        var root = document.documentElement;
        var timer;
        window.addEventListener(
          "resize",
          function () {
            root.classList.add("resizing");
            clearTimeout(timer);
            timer = setTimeout(function () {
              root.classList.remove("resizing");
            }, 150);
          },
          { passive: true },
        );
      })();
    </script>
  </head>
  <body>
    <section class="section section--primary section--nav section--wide print:hidden">
      <Nav />
    </section>
    <slot />
    {
      !hideFooter && (
        <section class="section section--wide section--footer print:hidden">
          <Footer />
        </section>
      )
    }
  </body>
</html>
